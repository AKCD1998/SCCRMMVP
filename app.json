{
  "expo": {
    "name": "SCCRM",
    "slug": "sccrm",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sccrm",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1FB8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.scgroup.sccrm",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1FB8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "49a5f35b-5f9c-43a8-8468-98d4d8150935"
      }
    }
  }
}
